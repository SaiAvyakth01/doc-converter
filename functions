export async function onRequestPost({ request, env }) {
  const formData = await request.formData();

  const file = formData.get("file");
  const to = formData.get("to");

  if (!file || !to) {
    return new Response("File or format missing", { status: 400 });
  }

  // 1. Create conversion job
  const jobRes = await fetch("https://api.cloudconvert.com/v2/jobs", {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${env.CLOUDCONVERT_API_KEY}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      tasks: {
        "import-file": { operation: "import/upload" },
        "convert-file": {
          operation: "convert",
          input: "import-file",
          output_format: to
        },
        "export-file": { operation: "export/url", input: "convert-file" }
      }
    })
  });

  const job = await jobRes.json();

  // 2. Upload file
  const uploadTask = job.data.tasks.find(t => t.name === "import-file");
  const uploadUrl = uploadTask.result.form.url;
  const uploadParams = uploadTask.result.form.parameters;

  const uploadForm = new FormData();
  Object.entries(uploadParams).forEach(([k, v]) => uploadForm.append(k, v));
  uploadForm.append("file", file);

  await fetch(uploadUrl, {
    method: "POST",
    body: uploadForm
  });

  // 3. Wait for conversion
  let finishedJob;
  for (let i = 0; i < 30; i++) {
    const poll = await fetch(
      `https://api.cloudconvert.com/v2/jobs/${job.data.id}`,
      { headers: { "Authorization": `Bearer ${env.CLOUDCONVERT_API_KEY}` } }
    );
    finishedJob = await poll.json();
    if (finishedJob.data.status === "finished") break;
    await new Promise(r => setTimeout(r, 1000));
  }

  // 4. Download converted file
  const exportTask = finishedJob.data.tasks.find(t => t.name === "export-file");
  const fileUrl = exportTask.result.files[0].url;

  const finalFile = await fetch(fileUrl);

  return new Response(finalFile.body, {
    headers: {
      "Content-Type": "application/octet-stream",
      "Content-Disposition": "attachment"
    }
  });
}
